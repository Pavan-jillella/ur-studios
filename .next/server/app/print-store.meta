{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/print-store/layout,_N_T_/print-store/page,_N_T_/print-store"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/print-store/__PAGE__",
    "/print-store",
    "/_index",
    "/_head"
  ]
}